# Environment
DISCORD_TOKEN=your_discord_bot_token
GEMINI_API_KEY=your_gemini_api_key
LASTFM_KEY=your_lastfm_api_key

# Optional — only needed for GCP deployment
# LOGS_BUCKET_NAME=your_gcs_bucket_name

# Optional — Discord channel ID for the suggestion box scraper
# SUGGESTION_CHANNEL_ID=1234567890123456789

# Optional — Google Cloud OAuth for YouTube Music (!ytlogin scrobbling)
# YOUTUBE_CLIENT_ID=your_gcp_client_id
# YOUTUBE_CLIENT_SECRET=your_gcp_client_secret
